<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================ -->
    <!-- TREE VIEW (read-only)                                            -->
    <!-- ================================================================ -->
    <record id="view_facility_audit_log_tree" model="ir.ui.view">
        <field name="name">facility.audit.log.tree</field>
        <field name="model">facility.audit.log</field>
        <field name="arch" type="xml">
            <tree string="Audit Log" create="0" edit="0" delete="0"
                  decoration-danger="action_type == 'unlink'"
                  decoration-warning="action_type == 'access_denied'"
                  decoration-info="action_type == 'create'">
                <field name="create_date" string="Timestamp"/>
                <field name="user_id"/>
                <field name="action_type" widget="badge"/>
                <field name="model_name"/>
                <field name="record_name"/>
                <field name="description"/>
                <field name="ip_address" optional="hide"/>
            </tree>
        </field>
    </record>

    <!-- ================================================================ -->
    <!-- FORM VIEW (read-only)                                            -->
    <!-- ================================================================ -->
    <record id="view_facility_audit_log_form" model="ir.ui.view">
        <field name="name">facility.audit.log.form</field>
        <field name="model">facility.audit.log</field>
        <field name="arch" type="xml">
            <form string="Audit Log Entry" create="0" edit="0" delete="0">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="display_name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="action_type"/>
                            <field name="model_name"/>
                            <field name="res_id"/>
                            <field name="record_name"/>
                        </group>
                        <group>
                            <field name="user_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="ip_address"/>
                            <field name="create_date" string="Timestamp"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                    <notebook>
                        <page string="Old Values">
                            <field name="old_values" nolabel="1" widget="text"/>
                        </page>
                        <page string="New Values">
                            <field name="new_values" nolabel="1" widget="text"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ================================================================ -->
    <!-- SEARCH VIEW                                                      -->
    <!-- ================================================================ -->
    <record id="view_facility_audit_log_search" model="ir.ui.view">
        <field name="name">facility.audit.log.search</field>
        <field name="model">facility.audit.log</field>
        <field name="arch" type="xml">
            <search string="Search Audit Log">
                <field name="user_id"/>
                <field name="model_name"/>
                <field name="record_name"/>
                <field name="description"/>
                <separator/>
                <filter string="Today" name="filter_today"
                        domain="[('create_date', '>=', context_today().strftime('%Y-%m-%d 00:00:00'))]"/>
                <filter string="This Week" name="filter_week"
                        domain="[('create_date', '>=', (context_today() - datetime.timedelta(days=7)).strftime('%Y-%m-%d 00:00:00'))]"/>
                <separator/>
                <filter string="Create" name="filter_create" domain="[('action_type', '=', 'create')]"/>
                <filter string="Update" name="filter_write" domain="[('action_type', '=', 'write')]"/>
                <filter string="Delete" name="filter_unlink" domain="[('action_type', '=', 'unlink')]"/>
                <filter string="Access Denied" name="filter_access_denied" domain="[('action_type', '=', 'access_denied')]"/>
                <filter string="Login / Logout" name="filter_auth" domain="[('action_type', 'in', ('login', 'logout'))]"/>
                <separator/>
                <filter string="My Activity" name="filter_my_activity" domain="[('user_id', '=', uid)]"/>
                <group expand="0" string="Group By">
                    <filter string="User" name="groupby_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Action" name="groupby_action" context="{'group_by': 'action_type'}"/>
                    <filter string="Model" name="groupby_model" context="{'group_by': 'model_name'}"/>
                    <filter string="Date" name="groupby_date" context="{'group_by': 'create_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ================================================================ -->
    <!-- ACTION                                                           -->
    <!-- ================================================================ -->
    <record id="action_facility_audit_log" model="ir.actions.act_window">
        <field name="name">Audit Log</field>
        <field name="res_model">facility.audit.log</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_facility_audit_log_search"/>
        <field name="context">{'search_default_filter_week': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No audit entries yet
            </p>
            <p>
                All create, update and delete actions on tracked models are logged here automatically.
            </p>
        </field>
    </record>

    <!-- ================================================================ -->
    <!-- MENU                                                             -->
    <!-- ================================================================ -->
    <menuitem id="menu_facility_security_root"
              name="Security"
              parent="menu_facility_root"
              sequence="90"/>

    <menuitem id="menu_facility_audit_log"
              name="Audit Log"
              parent="menu_facility_security_root"
              action="action_facility_audit_log"
              sequence="10"
              groups="facility_management.group_facility_auditor,facility_management.group_facility_manager"/>

</odoo>