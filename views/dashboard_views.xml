<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Tree View -->
    <record id="view_asset_dashboard_tree" model="ir.ui.view">
        <field name="name">asset.dashboard.tree</field>
        <field name="model">asset.dashboard</field>
        <field name="arch" type="xml">

            <tree string="Asset Dashboard"
                  create="1"
                  edit="1"
                  delete="1"
                  decoration-success="status == 'available'"
                  decoration-warning="status == 'maintenance'"
                  decoration-info="status == 'assigned'"
                  decoration-danger="status == 'retired'">

                <field name="asset_code"/>
                <field name="asset_name"/>
                <field name="category"/>
                <field name="owner"/>
                <field name="department"/>
                <field name="purchase_date"/>
                <field name="purchase_cost"/>
                <field name="status"/>

            </tree>

        </field>
    </record>


    <!-- Form View -->
    <record id="view_asset_dashboard_form" model="ir.ui.view">
        <field name="name">asset.dashboard.form</field>
        <field name="model">asset.dashboard</field>
        <field name="arch" type="xml">

            <form string="Asset Dashboard">

                <header>

                    <button name="action_mark_available"
                            string="Available"
                            type="object"
                            class="btn-primary"/>

                    <button name="action_mark_assigned"
                            string="Assign"
                            type="object"
                            class="btn-primary"/>

                    <button name="action_mark_maintenance"
                            string="Maintenance"
                            type="object"
                            class="btn-warning"/>

                    <button name="action_retire"
                            string="Retire"
                            type="object"
                            class="btn-danger"/>

                    <field name="status"
                           widget="statusbar"/>

                </header>

                <sheet>

                    <group>

                        <group string="Asset Information">

                            <field name="asset_name"/>

                            <field name="asset_code"
                                   readonly="1"/>

                            <field name="category"/>

                            <field name="status"/>

                        </group>

                        <group string="Ownership">

                            <field name="owner"/>

                            <field name="department"/>

                            <field name="purchase_date"/>

                            <field name="purchase_cost"/>

                        </group>

                    </group>

                    <notebook>

                        <page string="Description">

                            <field name="description"
                                   placeholder="Enter Asset Description"/>

                        </page>

                    </notebook>

                </sheet>

            </form>

        </field>
    </record>


    <!-- Search View -->

    <record id="view_asset_dashboard_search"
            model="ir.ui.view">

        <field name="name">
            asset.dashboard.search
        </field>

        <field name="model">
            asset.dashboard
        </field>

        <field name="arch" type="xml">

            <search>

                <field name="asset_name"/>

                <field name="asset_code"/>

                <field name="owner"/>

                <field name="department"/>

                <filter
                    string="Available"
                    name="available"
                    domain="[('status','=','available')]"/>

                <filter
                    string="Assigned"
                    name="assigned"
                    domain="[('status','=','assigned')]"/>

                <filter
                    string="Maintenance"
                    name="maintenance"
                    domain="[('status','=','maintenance')]"/>

                <filter
                    string="Retired"
                    name="retired"
                    domain="[('status','=','retired')]"/>

            </search>

        </field>

    </record>


    <!-- Action -->

    <record id="action_asset_dashboard"
            model="ir.actions.act_window">

        <field name="name">
            Asset Dashboard
        </field>

        <field name="res_model">
            asset.dashboard
        </field>

        <field name="view_mode">
            tree,form
        </field>

        <field name="search_view_id"
               ref="view_asset_dashboard_search"/>

    </record>

</odoo>