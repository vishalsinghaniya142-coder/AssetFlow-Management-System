<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ===========================
         Tree View
    ============================ -->

    <record id="view_asset_dashboard_tree" model="ir.ui.view">
        <field name="name">asset.dashboard.tree</field>
        <field name="model">asset.dashboard</field>
        <field name="arch" type="xml">
            <tree string="Assets">
                <field name="asset_name"/>
                <field name="asset_code"/>
                <field name="category"/>
                <field name="owner"/>
                <field name="department"/>
                <field name="purchase_cost"/>
                <field name="status"/>
            </tree>
        </field>
    </record>

    <!-- ===========================
         Form View
    ============================ -->

    <record id="view_asset_dashboard_form" model="ir.ui.view">
        <field name="name">asset.dashboard.form</field>
        <field name="model">asset.dashboard</field>
        <field name="arch" type="xml">
            <form string="Asset Dashboard">
                <sheet>

                    <group>

                        <group>
                            <field name="asset_name"/>
                            <field name="asset_code" readonly="1"/>
                            <field name="category"/>
                            <field name="status"/>
                        </group>

                        <group>
                            <field name="owner"/>
                            <field name="department"/>
                            <field name="purchase_date"/>
                            <field name="purchase_cost"/>
                        </group>

                    </group>

                    <notebook>

                        <page string="Description">
                            <field name="description"/>
                        </page>

                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

    <!-- ===========================
         Action Window
    ============================ -->

    <record id="action_asset_dashboard" model="ir.actions.act_window">
        <field name="name">Asset Dashboard</field>
        <field name="res_model">asset.dashboard</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>