<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================ -->
    <!-- TREE VIEW                                                        -->
    <!-- ================================================================ -->
    <record id="view_facility_maintenance_tree" model="ir.ui.view">
        <field name="name">facility.maintenance.tree</field>
        <field name="model">facility.maintenance</field>
        <field name="arch" type="xml">
            <tree string="Maintenance Requests" decoration-danger="is_overdue"
                  decoration-success="state == 'done'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="asset_id"/>
                <field name="maintenance_type"/>
                <field name="technician_id"/>
                <field name="scheduled_date"/>
                <field name="priority" widget="priority"/>
                <field name="is_overdue" invisible="1"/>
                <field name="actual_cost" sum="Total Cost"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state in ('confirmed','in_progress')"
                       decoration-success="state == 'done'"
                       decoration-danger="state == 'cancelled'"/>
            </tree>
        </field>
    </record>

    <!-- ================================================================ -->
    <!-- FORM VIEW                                                        -->
    <!-- ================================================================ -->
    <record id="view_facility_maintenance_form" model="ir.ui.view">
        <field name="name">facility.maintenance.form</field>
        <field name="model">facility.maintenance</field>
        <field name="arch" type="xml">
            <form string="Maintenance Request">
                <header>
                    <button name="action_confirm" type="object" string="Confirm"
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_start" type="object" string="Start"
                            class="oe_highlight" invisible="state != 'confirmed'"/>
                    <button name="%(facility_management.action_facility_maintenance_complete_wizard)d"
                            type="action" string="Mark Done"
                            class="oe_highlight" invisible="state != 'in_progress'"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="state in ('done', 'cancelled')"/>
                    <button name="action_reset_to_draft" type="object" string="Reset to Draft"
                            invisible="state not in ('cancelled',)"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,in_progress,done"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Overdue" bg_color="text-bg-danger"
                            invisible="not is_overdue"/>
                    <widget name="web_ribbon" title="Cancelled" bg_color="text-bg-danger"
                            invisible="state != 'cancelled'"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group name="left_col">
                            <field name="asset_id"/>
                            <field name="booking_id"/>
                            <field name="maintenance_type"/>
                            <field name="priority" widget="priority"/>
                            <field name="downtime_required"/>
                        </group>
                        <group name="right_col">
                            <field name="technician_id"/>
                            <field name="requested_by" readonly="1"/>
                            <field name="request_date"/>
                            <field name="scheduled_date"/>
                            <field name="is_overdue" invisible="1"/>
                        </group>
                    </group>
                    <group string="Execution" invisible="state in ('draft', 'confirmed')">
                        <group>
                            <field name="start_date" readonly="1"/>
                            <field name="completion_date" readonly="1"/>
                            <field name="duration_hours" readonly="1"/>
                        </group>
                        <group>
                            <field name="currency_id" invisible="1"/>
                            <field name="estimated_cost"/>
                            <field name="actual_cost"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description" placeholder="Describe the issue or work to be performed..."/>
                        </page>
                        <page string="Resolution" invisible="state not in ('in_progress', 'done')">
                            <field name="resolution_notes" placeholder="Notes on how the issue was resolved..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ================================================================ -->
    <!-- KANBAN VIEW (grouped by state)                                   -->
    <!-- ================================================================ -->
    <record id="view_facility_maintenance_kanban" model="ir.ui.view">
        <field name="name">facility.maintenance.kanban</field>
        <field name="model">facility.maintenance</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="state"/>
                <field name="is_overdue"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click #{record.is_overdue.raw_value ? 'border-danger' : ''}">
                            <div class="oe_kanban_content">
                                <strong><field name="name"/></strong>
                                <div><field name="asset_id"/></div>
                                <div>
                                    <field name="maintenance_type" widget="badge"/>
                                    <field name="priority" widget="priority"/>
                                </div>
                                <div class="text-muted">
                                    <field name="technician_id" widget="many2one_avatar_user"/>
                                    <field name="scheduled_date"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ================================================================ -->
    <!-- CALENDAR VIEW                                                    -->
    <!-- ================================================================ -->
    <record id="view_facility_maintenance_calendar" model="ir.ui.view">
        <field name="name">facility.maintenance.calendar</field>
        <field name="model">facility.maintenance</field>
        <field name="arch" type="xml">
            <calendar string="Maintenance Schedule" date_start="scheduled_date"
                      color="maintenance_type" mode="month" quick_create="0">
                <field name="name"/>
                <field name="asset_id"/>
                <field name="technician_id"/>
                <field name="maintenance_type"/>
            </calendar>
        </field>
    </record>

    <!-- ================================================================ -->
    <!-- SEARCH VIEW                                                      -->
    <!-- ================================================================ -->
    <record id="view_facility_maintenance_search" model="ir.ui.view">
        <field name="name">facility.maintenance.search</field>
        <field name="model">facility.maintenance</field>
        <field name="arch" type="xml">
            <search string="Search Maintenance Requests">
                <field name="name"/>
                <field name="asset_id"/>
                <field name="technician_id"/>
                <field name="booking_id"/>
                <separator/>
                <filter string="My Requests" name="my_requests"
                        domain="[('technician_id', '=', uid)]"/>
                <filter string="Overdue" name="overdue" domain="[('is_overdue', '=', True)]"/>
                <separator/>
                <filter string="Draft" name="filter_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmed" name="filter_confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter string="In Progress" name="filter_in_progress" domain="[('state', '=', 'in_progress')]"/>
                <filter string="Done" name="filter_done" domain="[('state', '=', 'done')]"/>
                <filter string="Cancelled" name="filter_cancelled" domain="[('state', '=', 'cancelled')]"/>
                <separator/>
                <filter string="Preventive" name="filter_preventive" domain="[('maintenance_type', '=', 'preventive')]"/>
                <filter string="Corrective" name="filter_corrective" domain="[('maintenance_type', '=', 'corrective')]"/>
                <filter string="Emergency" name="filter_emergency" domain="[('maintenance_type', '=', 'emergency')]"/>
                <separator/>
                <filter string="Scheduled Date" name="filter_scheduled_date" date="scheduled_date"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="groupby_state" context="{'group_by': 'state'}"/>
                    <filter string="Asset" name="groupby_asset" context="{'group_by': 'asset_id'}"/>
                    <filter string="Technician" name="groupby_technician" context="{'group_by': 'technician_id'}"/>
                    <filter string="Type" name="groupby_type" context="{'group_by': 'maintenance_type'}"/>
                    <filter string="Scheduled Date" name="groupby_scheduled_date" context="{'group_by': 'scheduled_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ================================================================ -->
    <!-- ACTION                                                           -->
    <!-- ================================================================ -->
    <record id="action_facility_maintenance" model="ir.actions.act_window">
        <field name="name">Maintenance Requests</field>
        <field name="res_model">facility.maintenance</field>
        <field name="view_mode">kanban,tree,form,calendar</field>
        <field name="search_view_id" ref="view_facility_maintenance_search"/>
        <field name="context">{'search_default_filter_draft': 0}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first maintenance request
            </p>
            <p>
                Track preventive and corrective maintenance work performed on your facility assets.
            </p>
        </field>
    </record>

    <!-- ================================================================ -->
    <!-- MENU                                                             -->
    <!-- ================================================================ -->
    <!-- NOTE: `menu_facility_root` is expected to be defined once, by
         whichever module module owns the top-level app menu (coordinate
         with Member 1/2). Referencing it here as a placeholder parent. -->
    <menuitem id="menu_facility_maintenance_root"
              name="Maintenance"
              parent="menu_facility_root"
              sequence="30"/>

    <menuitem id="menu_facility_maintenance_requests"
              name="Maintenance Requests"
              parent="menu_facility_maintenance_root"
              action="action_facility_maintenance"
              sequence="10"/>

</odoo>