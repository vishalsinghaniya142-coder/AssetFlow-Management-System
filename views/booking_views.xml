<odoo>
    <!-- Calendar View -->
    <record id="view_assetflow_booking_calendar" model="ir.ui.view">
        <name>assetflow.booking.calendar</name>
        <model>assetflow.booking</model>
        <arch type="xml">
            <calendar string="Resource Bookings" date_start="start_datetime" date_stop="end_datetime" color="asset_id" quick_add="False">
                <field name="asset_id"/>
                <field name="employee_id"/>
                <field name="state"/>
            </calendar>
        </arch>
    </record>

    <!-- Tree View -->
    <record id="view_assetflow_booking_tree" model="ir.ui.view">
        <name>assetflow.booking.tree</name>
        <model>assetflow.booking</model>
        <arch type="xml">
            <tree string="Resource Bookings" decoration-info="state == 'upcoming'" decoration-success="state == 'completed'">
                <field name="name"/>
                <field name="asset_id"/>
                <field name="employee_id"/>
                <field name="start_datetime"/>
                <field name="end_datetime"/>
                <field name="state" widget="badge"/>
            </tree>
        </arch>
    </record>

    <!-- Form View -->
    <record id="view_assetflow_booking_form" model="ir.ui.view">
        <name>assetflow.booking.form</name>
        <model>assetflow.booking</model>
        <arch type="xml">
            <form string="Booking Setup">
                <header>
                    <button name="action_complete" string="Mark Completed" type="object" class="btn-success" attrs="{'invisible': [('state', 'not in', ['upcoming', 'ongoing'])]}"/>
                    <button name="action_cancel" string="Cancel Booking" type="object" class="btn-danger" attrs="{'invisible': [('state', '=', 'cancelled')]}"/>
                    <field name="state" widget="statusbar" statusbar_visible="upcoming,ongoing,completed,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Resource Details">
                            <field name="asset_id" options="{'no_create': True}"/>
                            <field name="employee_id" options="{'no_create': True}"/>
                        </group>
                        <group string="Time Slot">
                            <field name="start_datetime"/>
                            <field name="end_datetime"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </arch>
    </record>

    <!-- Action -->
    <record id="action_assetflow_booking" model="ir.actions.act_window">
        <name>Resource Bookings</name>
        <res_model>assetflow.booking</res_model>
        <view_mode>calendar,tree,form</view_mode>
    </record>
</odoo>