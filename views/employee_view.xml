<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_employee_tree" model="ir.ui.view">
        <field name="name">asset.employee.tree</field>
        <field name="model">asset.employee</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="department_id"/>
            </tree>
        </field>
    </record>

    <record id="view_employee_form" model="ir.ui.view">
        <field name="name">asset.employee.form</field>
        <field name="model">asset.employee</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="employee_id"/>
                        <field name="email"/>
                        <field name="phone"/>
                        <field name="department_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>