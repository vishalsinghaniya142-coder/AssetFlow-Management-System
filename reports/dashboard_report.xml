<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Dashboard / Summary Report -->
    <record id="action_report_dashboard" model="ir.actions.report">
        <field name="name">Maintenance Dashboard Report</field>
        <field name="model">maintenance.request</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">dashboard.report_template</field>
    </record>

    <template id="dashboard.report_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <h1>Maintenance Dashboard</h1>
                    <p><strong>Total Requests:</strong> <span t-esc="total_requests"/></p>
                    <p><strong>Pending:</strong> <span t-esc="pending"/></p>
                    <!-- Add charts or summary stats -->
                </div>
            </t>
        </t>
    </template>
</odoo>